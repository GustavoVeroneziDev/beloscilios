# ─── Dependências ─────────────────────────────────────────────
/vendor/
/node_modules/

# ─── Uploads e logs ───────────────────────────────────────────
/uploads/*
!/uploads/.gitkeep
/logs/*
!/logs/.gitkeep

# ─── Configurações sensíveis ──────────────────────────────────
.env
.env.*
config/conexao.php
config/gemini.php
config/smtp_keys.php
config/evolution_keys.php
config/google_oauth.php
config/*_keys.php
config/*_secret*.php
config/*_oauth.php

# ─── PHP ──────────────────────────────────────────────────────
*.log
error_log
php_errorlog
/composer.lock

# ─── Cache / sessões locais ───────────────────────────────────
/cache/*
!/cache/.gitkeep
/tmp/*
/temp/*
/sessions/*

# ─── Backups e arquivos temporários ──────────────────────────
*.bak
*.backup
*.old
*.orig
*.sql.gz
*.tar.gz
*.zip
*~
*.swp
*.swo

# ─── IDEs ─────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.phpstorm.meta.php
_ide_helper.php
.php-version

# ─── Sistema operacional ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── XAMPP / servidor local ───────────────────────────────────
*.local.php
local_config.php
